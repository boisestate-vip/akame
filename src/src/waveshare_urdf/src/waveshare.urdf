<?xml version="1.0"?>
<robot name="waveshare" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- most everything is copied from here -->
  <!-- https://docs.nav2.org/setup_guides/urdf/setup_urdf.html -->

  <!-- Define robot constants -->
  <xacro:property name="base_width" value="0.076"/>
  <xacro:property name="base_length" value="0.183"/>
  <xacro:property name="base_height" value="0.056"/>

  <xacro:property name="wheel_radius" value="0.037"/>
  <xacro:property name="wheel_width" value="0.0425"/>
  <xacro:property name="wheel_ygap" value="0.005"/>
  <xacro:property name="wheel_zoff" value="0.0215"/>
  <xacro:property name="wheel_xoff" value="0.045"/>

  <xacro:property name="synexens_height" value="0.025"/>

  <!-- Robot Base -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="Green">
        <color rgba="0.0 1.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Robot Footprint -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0.0 0.0 ${-(wheel_radius+wheel_zoff)}" rpy="0 0 0"/>
  </joint>

  <!-- lidar box -->
  <link name="synexens_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
      <box size="0.01 0.04 ${synexens_height}"/>
      </geometry>
      <material name="Grey">
        <color rgba="0.8 0.8 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="synexens_joint" type="fixed">
    <parent link="base_link"/>
    <child link="synexens_link"/>
    <origin xyz="${base_length/2 - 0.015} 0.0 ${base_height/2 + synexens_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Wheels -->
  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="Purple">
          <color rgba="0.5 0.0 0.5 1.0"/>
        </material>
      </visual>
    </link>

    <joint name="${prefix}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_link"/>
      <origin xyz="${x_reflect*wheel_xoff} ${y_reflect*(base_width/2+wheel_ygap)} ${-wheel_zoff}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="drivewhl_fl" x_reflect="1" y_reflect="1" />
  <xacro:wheel prefix="drivewhl_fr" x_reflect="1" y_reflect="-1" />
  <xacro:wheel prefix="drivewhl_bl" x_reflect="-1" y_reflect="1" />
  <xacro:wheel prefix="drivewhl_br" x_reflect="-1" y_reflect="-1" />

</robot>
